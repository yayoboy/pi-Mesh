# Percorsi
SERIAL_PORT=/dev/ttyMESHTASTIC
DB_PERSISTENT=/home/pi/meshtastic-pi/data/mesh.db
DB_SYNC_INTERVAL=300

# GPIO encoder 1 (navigazione globale)
# NOTA: GPIO 17 e 27 sono usati dal display Waveshare 3.5" (Touch IRQ e LCD RST)
ENC1_A=23
ENC1_B=24
ENC1_SW=22

# GPIO encoder 2 (contestuale)
ENC2_A=5
ENC2_B=6
ENC2_SW=13

# Sensori I2C
# I2C_AUTOSCAN=1  → scansiona automaticamente il bus all'avvio (default)
# I2C_AUTOSCAN=0  → usa solo I2C_SENSORS (lista esplicita)
I2C_AUTOSCAN=1
# Formato: "bme280:0x76,ina219:0x40" — sovrascrive l'autoscan per quell'indirizzo
I2C_SENSORS=

# Mappa (Italia centrale come default)
MAP_LAT_MIN=41.0
MAP_LAT_MAX=43.0
MAP_LON_MIN=11.5
MAP_LON_MAX=14.5
MAP_ZOOM_MIN=8
MAP_ZOOM_MAX=12

# Display
DISPLAY_ROTATION=0

# UI
UI_THEME=dark

# Map tiles
MAP_LOCAL_TILES=0
MAP_REGION=italia

BUZZER_PIN=0
# Suggerito: BUZZER_PIN=12 (GPIO 12, pin fisico 32, PWM hardware, libero dal display)
